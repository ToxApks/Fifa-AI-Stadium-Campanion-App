# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# GOOGLE_WEB_CLIENT_ID: Web Client ID from the Google Cloud/Firebase Console
# This is required for real Google Sign-In with Credential Manager.
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID

# FOOTBALL_API_KEY: Token for football-data.org API
FOOTBALL_API_KEY=YOUR_FOOTBALL_API_KEY

# API_FOOTBALL_KEY: Token for API-Football (RapidAPI)
API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY
